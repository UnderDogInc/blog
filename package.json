{
  "name": "blog",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node scripts/dev.mjs",
    "dev:blog": "nuxt dev apps/blog --port 3000",
    "dev:writer": "nuxt dev apps/writer --port 3001",
    "dev:resto": "nuxt dev apps/resto --port 3002",
    "build": "node scripts/build.mjs",
    "build:blog": "nuxt build apps/blog",
    "build:writer": "nuxt build apps/writer",
    "build:resto": "nuxt build apps/resto",
    "preview:blog": "nuxt preview apps/blog --port 3000",
    "preview:writer": "nuxt preview apps/writer --port 3001",
    "preview:resto": "nuxt preview apps/resto --port 3002",
    "postinstall": "nuxt prepare apps/blog && nuxt prepare apps/writer && nuxt prepare apps/resto",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "prod": "pnpm build && pnpm pm2:start"
  },
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/critters": "^0.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/extension-file-handler": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/vue-3": "^3.23.6",
    "@vueuse/nuxt": "14.3.0",
    "daisyui": "^5.5.19",
    "eslint-plugin-vue": "^10.9.1",
    "nodemailer": "^8.0.10",
    "nuxt": "^4.4.5",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/nodemailer": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3"
  }
}
