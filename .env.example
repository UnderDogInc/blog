# =============================================================================
# Frontend monorepo (blog) — скопируй в .env в корне репозитория:
#   cp .env.example .env
# =============================================================================

# API (dev: через proxy Nuxt, запросы идут на /api того же порта)
NUXT_PUBLIC_API_BASE=/api
NUXT_API_PROXY_TARGET=http://localhost:4000
# Origin backend для картинок, если apiBase относительный (опционально в dev)
# NUXT_PUBLIC_API_ORIGIN=http://localhost:4000

# Production — полный URL API (proxy не используется):
# NUXT_PUBLIC_API_BASE=https://api.rassvet.click/api

# Локальные URL приложений (dev)
NUXT_PUBLIC_BLOG_URL=http://localhost:3000
NUXT_PUBLIC_WRITER_URL=http://localhost:3001

# siteUrl задаётся отдельно при деплое каждого app (см. README)

# Production:
# NUXT_PUBLIC_BLOG_URL=https://blog.rassvet.click
# NUXT_PUBLIC_WRITER_URL=https://writer.rassvet.click
# NUXT_PUBLIC_SITE_URL=https://blog.rassvet.click   # для apps/blog
# NUXT_PUBLIC_SITE_URL=https://writer.rassvet.click # для apps/writer
# NUXT_PUBLIC_SITE_URL=https://resto.rassvet.click  # для apps/resto

# =============================================================================
# Contact form (Nuxt server → SMTP, без Nest)
# Работает в любом app, который extends layers/shared
# =============================================================================
NUXT_CONTACT_SMTP_HOST=smtp.yandex.ru
NUXT_CONTACT_SMTP_PORT=465
# NUXT_CONTACT_SMTP_SECURE=false   # для порта 587 (STARTTLS)
NUXT_CONTACT_SMTP_USER=your@yandex.ru
NUXT_CONTACT_SMTP_PASS=your-app-password
NUXT_CONTACT_TO=your@mail.com
# NUXT_CONTACT_FROM=your@yandex.ru
# NUXT_CONTACT_FROM_NAME=My Bot
# NUXT_CONTACT_SITE_NAME=RestoPro

# mail.ru example:
# NUXT_CONTACT_SMTP_HOST=smtp.mail.ru
# NUXT_CONTACT_SMTP_PORT=587
# NUXT_CONTACT_SMTP_SECURE=false
