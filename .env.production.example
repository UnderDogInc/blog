# =============================================================================
# Production — rassvet.click
# Скопируй на сервер: cp .env.production.example .env
# Заполни NUXT_CONTACT_SMTP_PASS и пересобери: pnpm build && pnpm pm2:restart
# =============================================================================

NODE_ENV=production

# --- Публичные URL приложений ---
NUXT_PUBLIC_BLOG_URL=https://blog.rassvet.click
NUXT_PUBLIC_WRITER_URL=https://writer.rassvet.click

# PM2 подставляет свой siteUrl в каждый процесс (ecosystem.config.cjs)
NUXT_PUBLIC_BLOG_SITE_URL=https://blog.rassvet.click
NUXT_PUBLIC_WRITER_SITE_URL=https://writer.rassvet.click
NUXT_PUBLIC_RESTO_SITE_URL=https://resto.rassvet.click

# --- API блога (Nest на api2.rassvet.click) ---
# blog/writer: nginx проксирует /api и /assets → api2, поэтому base относительный
NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_API_ORIGIN=https://api2.rassvet.click

# dev-only, в production не используется
# NUXT_API_PROXY_TARGET=http://127.0.0.1:4000

# --- Форма обратной связи (resto, Nitro → SMTP) ---
NUXT_CONTACT_SMTP_HOST=smtp.mail.ru
NUXT_CONTACT_SMTP_PORT=587
NUXT_CONTACT_SMTP_SECURE=false
NUXT_CONTACT_SMTP_USER=restoran_bot@mail.ru
NUXT_CONTACT_SMTP_PASS=CHANGE_ME
NUXT_CONTACT_TO=koalaboy@yandex.ru
NUXT_CONTACT_FROM=restoran_bot@mail.ru
NUXT_CONTACT_FROM_NAME=RestoPro
